    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a professional, warm interview invitation email for this candidate.\n\nCandidate Name: {{ $json.candidateName }}\nJob Title: {{ $json.jobTitle }}\nInterview Date: {{ $json.interviewDate || 'TBD - we will follow up shortly' }}\nInterview Link: {{ $json.interviewLink || 'Details will be sent separately' }}\nHiring Manager: {{ $json.hiringManagerName }}\nCandidate Summary: {{ $json.summary }}\nKey Strengths: {{ $json.strengths }}\n\nWrite ONLY the email body HTML (no subject line). Make it enthusiastic but professional. Mention 1-2 of their specific strengths. Keep it under 200 words.",
        "options": {
          "systemMessage": "You are a professional talent acquisition specialist. Write warm, personalized, professional emails. Return only the email body as HTML, no preamble or explanation."
        }
      },
      "id": "7ee14470-5b19-4c9b-a56b-1ba6153aea81",
      "name": "Generate Interview Email",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        896,
        0
      ]
    },
    {
      "parameters": {
        "sendTo": "={{ $(\"Merge Action Data\").first().json.candidateEmail }}",
        "subject": "={{ \"Interview Invitation: \" + $(\"Merge Action Data\").first().json.jobTitle + \" at Your Company\" }}",
        "message": "={{ $json.output }}",
        "options": {
          "appendAttribution": false
        }
      },
