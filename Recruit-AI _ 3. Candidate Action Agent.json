    {
      "parameters": {
        "jsCode": "\nconst candidate = $input.first().json;\nconst body = $('Candidate Action Webhook').first().json.body;\nreturn [{ json: {\n  ...candidate,\n  action: body.action,\n  interviewDate: body.interviewDate || null,\n  interviewLink: body.interviewLink || null,\n  hiringManagerName: body.hiringManagerName || 'the hiring team'\n}}];\n"
      },
